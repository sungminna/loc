{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Skill"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(mkfs:*)",
      "Bash(dd if=/dev/*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ]
  },
  "env": {
    "LOC_ARTIFACT_DIR": "data/runs",
    "BUN_INSTALL": "/root/.bun"
  }
}
