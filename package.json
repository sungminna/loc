{
  "name": "loc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply loc-app --local",
    "db:migrate:remote": "wrangler d1 migrations apply loc-app --remote",
    "db:studio": "drizzle-kit studio",
    "dashboard:dev": "vite --config src/dashboard/vite.config.ts",
    "dashboard:build": "vite build --config src/dashboard/vite.config.ts",
    "render:test": "bun src/sandbox/render-reel.ts test",
    "seed:audio": "bun scripts/seed-audio.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@cloudflare/sandbox": "^0.4.0",
    "@google/genai": "^1",
    "@paralleldrive/cuid2": "^2.2.2",
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@tanstack/react-query": "^5.50.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "cron-parser": "^5.0.0",
    "cronstrue": "^2.50.0",
    "drizzle-orm": "^0.36.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "remotion": "^4.0.0",
    "superjson": "^2.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  }
}
